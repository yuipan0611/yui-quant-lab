# Copy to .env and fill in values. Do not commit .env.
# The app loads only this file via python-dotenv (see app.py). systemd unit
# should NOT duplicate these as EnvironmentFile.

# TradingView alert JSON field "secret" must match exactly.
TV_WEBHOOK_SECRET=change_me_to_a_long_random_string

# Telegram (optional). ENABLE_TELEGRAM_NOTIFY=true to call API; empty -> print fallback.
ENABLE_TELEGRAM_NOTIFY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Webhook short idempotency window (seconds). File: output/webhook_dedupe.json
WEBHOOK_DEDUPE_TTL_SEC=300

# stdout raw_request logging: compact | verbose | metadata_only | off
RAW_REQUEST_LOG_MODE=compact
