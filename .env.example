# Copy to .env and adjust. (.env is gitignored.)

# Decision notify:
# - true  -> Telegram sendMessage
# - unset/empty -> stdout fallback (mode=print)
# - false/other non-empty -> stdout only (mode=disabled)
ENABLE_TELEGRAM_NOTIFY=true

# Required when ENABLE_TELEGRAM_NOTIFY=true
# BotFather token format: 123456789:AA...
TELEGRAM_BOT_TOKEN=your_token_here

# Numeric chat id, not bot username. Example: 123456789 or -1001234567890
TELEGRAM_CHAT_ID=your_chat_id

# Shared secret used by /tv-webhook payload field "secret"
# Use a long random string and keep the same value in TradingView alert JSON.
TV_WEBHOOK_SECRET=your_secret_here
