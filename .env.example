# Copy to .env and adjust. (.env is gitignored.)

# Decision notify: unset or empty -> stdout only (mode=print); "true" -> Telegram sendMessage;
# any other non-empty value (e.g. false) -> stdout only (mode=disabled).
ENABLE_TELEGRAM_NOTIFY=false

# Required when ENABLE_TELEGRAM_NOTIFY=true (BotFather token and target chat id).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
